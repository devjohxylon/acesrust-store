# Copy to .env.local for local dev, or add these in the Vercel dashboard for production.

# [REQUIRED] Tip4Serv API key from https://tip4serv.com/dashboard/api-keys
# Must include read-products permission (and read-categories if available)
TIP4SERV_API_KEY=your_api_key_here

# [REQUIRED] Public site URL — production domain on Vercel
NEXT_PUBLIC_SITE_URL=https://acesrust.com

# [OPTIONAL] Tip4Serv API base URL
TIP4SERV_API_BASE=https://api.tip4serv.com/v1

# [OPTIONAL] Maintenance mode — set to true to show maintenance page to visitors
MAINTENANCE_MODE=false

# [OPTIONAL] Secret to bypass maintenance (visit https://acesrust.com?bypass=YOUR_SECRET)
MAINTENANCE_BYPASS_SECRET=change-me-to-a-long-random-string

# [OPTIONAL] Custom message on the maintenance page
MAINTENANCE_MESSAGE=We are performing scheduled maintenance. The store will be back online shortly.

# [OPTIONAL] Handle Steam/Discord login on your site instead of Tip4Serv checkout
HANDLE_CUSTOMER_IDENTIFICATION=false

# [OPTIONAL] Discord OAuth (required for site Login button + optional checkout login)
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Site login callback — add this EXACT URL in Discord → OAuth2 → Redirects:
#   https://acesrust.com/api/auth/discord/callback
# (Checkout uses /api/oauth/discord/callback — that is a different URL.)
DISCORD_AUTH_REDIRECT_URI=https://acesrust.com/api/auth/discord/callback
NEXT_PUBLIC_DISCORD_REDIRECT_URI=https://acesrust.com/api/oauth/discord/callback

# [ADMIN PANEL] Password to access /admin (leaderboard + wipe schedule).
# Use a long random string. Required for the admin panel to work.
ADMIN_PASSWORD=change-me-to-a-long-random-string

# [ADMIN STORAGE] Vercel Blob stores the leaderboard + wipe data in production.
# Create a Blob store in the Vercel dashboard (Storage tab) and this is added
# automatically. No database needed.
BLOB_READ_WRITE_TOKEN=

# [DISCORD BOT] Shared secret the bot sends as `Authorization: Bearer <secret>` to
# POST /api/discord/ingest. Same value in Astral Bot .env. Used for both:
#   leaderboard:    { "type": "leaderboard", "primaryImageUrl": "...", "messageId": "...", "timestamp": "..." }
#   server pop:     { "type": "server_status", "players": 12, "maxPlayers": 50, "queued": 3, "online": true }
WEBSITE_API_SECRET=change-me-to-a-long-random-string

# [TIP4SERV WEBHOOK] Secret for the "recent purchases" ticker.
# In Tip4Serv dashboard, set the webhook URL to:
#   https://acesrust.com/api/webhooks/tip4serv?key=YOUR_SECRET
# and set the same value here.
TIP4SERV_WEBHOOK_SECRET=change-me-to-a-long-random-string

# [LOCAL DEV] Persist admin data to .data/cms.json instead of Blob (dev only).
# Leave BLOB_READ_WRITE_TOKEN empty locally and set this to true.
LOCAL_CMS=true

# [ENGAGEMENT HUB] Supabase project for player profiles, points, achievements,
# challenges, and the activity feed. Create a project at https://supabase.com,
# run supabase/schema.sql in the SQL editor, then set these (Settings > API).
# Leave empty to disable engagement features — the rest of the site works as-is.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# [ENGAGEMENT HUB] Secret that signs the Discord login session cookie.
# Use a long random string. Falls back to DISCORD_CLIENT_SECRET when unset.
AUTH_SECRET=change-me-to-a-long-random-string

# [DISCORD INTEGRATION] Bot token for auto role grants and streak reminder DMs.
# Bot must be in your server with the Manage Roles permission, and its role must
# sit above the Site Legend role in the role list. All optional — leave empty
# and redemptions fall back to the manual admin queue.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_LEGEND_ROLE_ID=

# [DISCORD INTEGRATION] Channel webhook that mirrors site milestones
# (achievements, streaks, challenge completions) into Discord.
# Create in channel settings > Integrations > Webhooks.
DISCORD_FEED_WEBHOOK_URL=

# [DISCORD INTEGRATION] Protects the daily streak-reminder cron endpoint.
# Vercel sends this automatically as `Authorization: Bearer <secret>` when set.
CRON_SECRET=change-me-to-a-long-random-string
